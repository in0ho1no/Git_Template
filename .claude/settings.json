{
  "permissions": {
    "defaultMode": "default",
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/credentials*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.gnupg/**)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(rm -rf $HOME*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git filter-branch*)",
      "Bash(git filter-repo*)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git tag -d *)",
      "Bash(git branch -D *)",
      "Bash(npm publish*)",
      "Bash(npm install *)",
      "Bash(pip install *)",
      "Bash(uv add *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "WebFetch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Read|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/pre_tool_inspect.py"
          }
        ]
      }
    ]
  }
}
