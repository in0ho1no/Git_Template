#!/bin/sh

set -eu

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root"

staged_files=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$staged_files" ]; then
  exit 0
fi

check_pattern() {
  description=$1
  regex=$2

  set --
  while IFS= read -r path; do
    [ -n "$path" ] && set -- "$@" "$path"
  done <<EOF
$staged_files
EOF

  matches=$(git grep --cached -n -I -E -e "$regex" -- "$@" ':(exclude)git-setup/hooks/pre-commit' 2>/dev/null || true)

  if [ -n "$matches" ]; then
    echo "[security] $description" >&2
    printf '%s\n' "$matches" >&2
    return 1
  fi

  return 0
}

check_pattern "Python の shell=True を検出しました" 'subprocess\.(call|run|Popen)\([^#\n]*shell[[:space:]]*=[[:space:]]*True'
check_pattern "Python の os.system を検出しました" 'os\.system\('
check_pattern "Python の eval / exec を検出しました" '\beval\(|\bexec\('
check_pattern "Node.js の child_process 実行を検出しました" 'child_process\.(exec|execSync)\('
check_pattern "shell: true の実行設定を検出しました" 'shell[[:space:]]*:[[:space:]]*true'
check_pattern "curl | sh を検出しました" 'curl[[:space:]].*\|[[:space:]]*sh'
check_pattern "wget | sh を検出しました" 'wget[[:space:]].*\|[[:space:]]*sh'

check_pattern "AWS キーらしき文字列を検出しました" 'AKIA[0-9A-Z]{16}|ASIA[0-9A-Z]{16}'
check_pattern "GitHub トークンらしき文字列を検出しました" 'ghp_[A-Za-z0-9]{30,}|github_pat_[A-Za-z0-9_]{20,}'
check_pattern "Slack トークンらしき文字列を検出しました" 'xox[baprs]-[A-Za-z0-9-]{10,}'
check_pattern "Stripe の secret key らしき文字列を検出しました" 'sk_live_[A-Za-z0-9]{16,}'

exit 0
